# Backend environment. Copy to .env and fill in values.
#
# Required for run:
#   POSTGRES_URL  - PostgreSQL connection string (required)
#   JWT_SECRET    - secret for JWT signing
#
# Optional:
#   REDIS_URL     - Redis connection string. If set, backend connects on startup.
#                   If unset, Redis is not used (no warning). Example: redis://localhost:6379
#   PORT          - HTTP port (default 4000)
#   NODE_ENV      - development | production
#   TELEGRAM_BOT_TOKEN - for Telegram Mini App auth
#
# Run with Redis:
#   1. Install Redis (e.g. apt install redis-server / brew install redis)
#   2. Start Redis: redis-server
#   3. Set REDIS_URL=redis://localhost:6379 in .env
#   4. npm run build && npm run start

NODE_ENV=development
PORT=4000

POSTGRES_URL=postgres://user:password@localhost:5432/durak
REDIS_URL=redis://localhost:6379

TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_WEBAPP_SECRET=your_webapp_secret_if_used

JWT_SECRET=change_me
JWT_EXPIRES_IN=3600

LOG_LEVEL=info
